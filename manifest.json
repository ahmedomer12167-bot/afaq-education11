<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>آفاق التعليمية</title>
  <meta name="theme-color" content="#071a4a" />
  <link rel="manifest" href="manifest.json" />
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div id="toast"></div>
  <header class="topbar glass">
    <div class="brand"><span class="logo">آ</span><div><b id="platformName">آفاق التعليمية</b><small>منصة تعليمية متزامنة</small></div></div>
    <nav id="topNav" class="hide"><button onclick="goHome()">الرئيسية</button><button onclick="logout()">تسجيل الخروج</button></nav>
  </header>

  <main id="app"></main>

  <template id="homeTpl">
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-title">
        <h1>آفاق التعليمية</h1>
        <p>منصة تعليمية متكاملة نحو مستقبل أفضل</p>
      </div>
      <div class="role-grid">
        <article class="role-card admin-card" data-role="admin">
          <div class="role-art">💼</div><h2>مدير</h2><p>إدارة المنصة والمستخدمين والتقارير والإعدادات</p><button onclick="showLogin('admin')">تسجيل الدخول</button>
        </article>
        <article class="role-card teacher-card" data-role="teacher">
          <div class="role-art">📚</div><h2>مدرس</h2><p>إدارة الفصول والمواد والاختبارات والأنشطة</p><button onclick="showLogin('teacher')">تسجيل الدخول</button>
        </article>
        <article class="role-card student-card" data-role="student">
          <div class="role-art">🎒</div><h2>طالب</h2><p>التعلم والدروس والاختبارات ومتابعة التقدم</p><button onclick="showStudentGate()">دخول الطالب</button>
        </article>
        <article class="role-card parent-card" data-role="parent">
          <div class="role-art">👨‍👩‍👧</div><h2>ولي الأمر</h2><p>متابعة أداء الأبناء والتواصل مع المدرسة</p><button onclick="showLogin('parent')">تسجيل الدخول</button>
        </article>
      </div>
      <div class="features glass"><span>🎓 تعلم بذكاء</span><span>📖 تطور باستمرار</span><span>🏆 مستقبل أفضل</span></div>
    </section>
  </template>
</body>
<script src="app.js"></script>
</html>
